	}

	TextBlock.font-(string family) {
		FontFamily: Amx.DynamicResource<FontFamily>("--font-" + family);
	}

	TemplatedControl.font-thin {
		FontWeight: Amx.DynamicResource<FontWeight>("--font-weight-thin");
	}

	TemplatedControl.font-extralight {
		FontWeight: Amx.DynamicResource<FontWeight>("--font-weight-extralight");
