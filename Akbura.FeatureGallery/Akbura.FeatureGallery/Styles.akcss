	Border.shadow {
		BoxShadow: Amx.DynamicResource<BoxShadows>("--shadow-sm");
	}

	Border.shadow-2xs {
		BoxShadow: Amx.DynamicResource<BoxShadows>("--shadow-2xs");
	}

	Border.shadow-xs {
		BoxShadow: Amx.DynamicResource<BoxShadows>("--shadow-xs");
	}

	Border.shadow-sm {
