	}

	TextBlock.whitespace-nowrap {
		TextWrapping: NoWrap;
	}

	TextBlock.whitespace-normal {
		TextWrapping: Wrap;
	}

	TextBlock.truncate {
		TextWrapping: NoWrap;
		TextTrimming: CharacterEllipsis;
	}

	// Borders, radii, and shadows.
	Border.border-(double width) {
		AkburaControl.ExplicitLeftBorderThickness: width;
		AkburaControl.ExplicitTopBorderThickness: width;
		AkburaControl.ExplicitRightBorderThickness: width;
		AkburaControl.ExplicitBottomBorderThickness: width;
	}

	Border.border-(string color)-(int shade) {
		BorderBrush: Amx.DynamicResource<IBrush>("--color-" + color + "-" + shade);
	}

	Border.rounded-none {
		CornerRadius: new CornerRadius(0);
	}

	Border.rounded-xs {
		CornerRadius: Amx.DynamicResource<CornerRadius>("--radius-xs");
	}

	Border.rounded-sm {
		CornerRadius: Amx.DynamicResource<CornerRadius>("--radius-sm");
	}

	Border.rounded-md {
		CornerRadius: Amx.DynamicResource<CornerRadius>("--radius-md");
	}

	Border.rounded-lg {
		CornerRadius: Amx.DynamicResource<CornerRadius>("--radius-lg");
	}

	Border.rounded-xl {
		CornerRadius: Amx.DynamicResource<CornerRadius>("--radius-xl");
	}

	Border.rounded-2xl {
		CornerRadius: Amx.DynamicResource<CornerRadius>("--radius-2xl");
	}

	Border.rounded-3xl {
		CornerRadius: Amx.DynamicResource<CornerRadius>("--radius-3xl");
	}

	Border.rounded-4xl {
		CornerRadius: Amx.DynamicResource<CornerRadius>("--radius-4xl");
	}

	Border.rounded-full {
		CornerRadius: new CornerRadius(9999);
	}

	Border.rounded-(string radius) {
		CornerRadius: Amx.DynamicResource<CornerRadius>("--radius-" + radius);
	}

	TemplatedControl.border-(double width) {
		AkburaControl.ExplicitLeftBorderThickness: width;
		AkburaControl.ExplicitTopBorderThickness: width;
		AkburaControl.ExplicitRightBorderThickness: width;
		AkburaControl.ExplicitBottomBorderThickness: width;
	}

	TemplatedControl.border-(string color)-(int shade) {
		BorderBrush: Amx.DynamicResource<IBrush>("--color-" + color + "-" + shade);
	}

