<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Tailwind-compatible defaults expressed in Avalonia device-independent pixels. -->
  <x:Double x:Key="--spacing">4</x:Double>

  <FontFamily x:Key="--font-sans">Segoe UI, Arial, Helvetica, Noto Sans, Liberation Sans, $Default</FontFamily>
  <FontFamily x:Key="--font-serif">Georgia, Times New Roman, Noto Serif, Liberation Serif, $Default</FontFamily>
  <FontFamily x:Key="--font-mono">Cascadia Mono, Consolas, Menlo, Monaco, Noto Sans Mono, Liberation Mono, $Default</FontFamily>

  <x:Double x:Key="--text-xs">12</x:Double>
  <x:Double x:Key="--text-sm">14</x:Double>
  <x:Double x:Key="--text-base">16</x:Double>
  <x:Double x:Key="--text-lg">18</x:Double>
  <x:Double x:Key="--text-xl">20</x:Double>
  <x:Double x:Key="--text-2xl">24</x:Double>
  <x:Double x:Key="--text-3xl">30</x:Double>
  <x:Double x:Key="--text-4xl">36</x:Double>
  <x:Double x:Key="--text-5xl">48</x:Double>
  <x:Double x:Key="--text-6xl">60</x:Double>
  <x:Double x:Key="--text-7xl">72</x:Double>
  <x:Double x:Key="--text-8xl">96</x:Double>
  <x:Double x:Key="--text-9xl">128</x:Double>

  <FontWeight x:Key="--font-weight-thin">Thin</FontWeight>
  <FontWeight x:Key="--font-weight-extralight">ExtraLight</FontWeight>
  <FontWeight x:Key="--font-weight-light">Light</FontWeight>
  <FontWeight x:Key="--font-weight-normal">Normal</FontWeight>
  <FontWeight x:Key="--font-weight-medium">Medium</FontWeight>
  <FontWeight x:Key="--font-weight-semibold">SemiBold</FontWeight>
  <FontWeight x:Key="--font-weight-bold">Bold</FontWeight>
  <FontWeight x:Key="--font-weight-extrabold">ExtraBold</FontWeight>
  <FontWeight x:Key="--font-weight-black">Black</FontWeight>

  <CornerRadius x:Key="--radius-xs">2</CornerRadius>
  <CornerRadius x:Key="--radius-sm">4</CornerRadius>
  <CornerRadius x:Key="--radius-md">6</CornerRadius>
  <CornerRadius x:Key="--radius-lg">8</CornerRadius>
  <CornerRadius x:Key="--radius-xl">12</CornerRadius>
  <CornerRadius x:Key="--radius-2xl">16</CornerRadius>
  <CornerRadius x:Key="--radius-3xl">24</CornerRadius>
  <CornerRadius x:Key="--radius-4xl">32</CornerRadius>

  <BoxShadows x:Key="--shadow-2xs">0 1 0 0 #0D000000</BoxShadows>
  <BoxShadows x:Key="--shadow-xs">0 1 2 0 #0D000000</BoxShadows>
  <BoxShadows x:Key="--shadow-sm">0 1 3 0 #1A000000, 0 1 2 -1 #1A000000</BoxShadows>
  <BoxShadows x:Key="--shadow-md">0 4 6 -1 #1A000000, 0 2 4 -2 #1A000000</BoxShadows>
  <BoxShadows x:Key="--shadow-lg">0 10 15 -3 #1A000000, 0 4 6 -4 #1A000000</BoxShadows>
  <BoxShadows x:Key="--shadow-xl">0 20 25 -5 #1A000000, 0 8 10 -6 #1A000000</BoxShadows>
  <BoxShadows x:Key="--shadow-2xl">0 25 50 -12 #40000000</BoxShadows>

  <!-- Tailwind default color palette. Applications can override any key locally. -->
  <SolidColorBrush x:Key="--color-transparent" Color="Transparent" />
  <SolidColorBrush x:Key="--color-black" Color="#000000" />
  <SolidColorBrush x:Key="--color-white" Color="#FFFFFF" />

  <!-- red -->
